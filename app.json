{
  "expo": {
    "name": "DraftIQ",
    "slug": "draftiq",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "draftiq",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0D0D0F",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D0D0F"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.draftiq.app",
      "usesAppleSignIn": true,
      "buildNumber": "1",
      "infoPlist": {
        "UIBackgroundModes": ["remote-notification", "fetch"],
        "NSCameraUsageDescription": "DraftIQ uses your camera to update your profile photo.",
        "NSPhotoLibraryUsageDescription": "DraftIQ saves your draft recap share cards to your photo library."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0D0D0F"
      },
      "package": "com.draftiq.app",
      "versionCode": 1,
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-apple-authentication",
      "./plugins/withFmtFix",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#00FF87",
          "defaultChannel": "default",
          "sounds": []
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "48686907-7ba8-4eb9-acc5-d15912ae63bc"
      }
    }
  }
}
