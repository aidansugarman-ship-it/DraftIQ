rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can only read/write their own profile
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Players are public read, admin-only write
    match /players/{playerId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Articles are public read, admin-only write
    match /articles/{articleId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Injuries are public read, admin-only write
    match /injuries/{injuryId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Mock drafts: users own their own
    match /mockDrafts/{draftId} {
      allow read, write: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
    }

    // Trades: users own their own
    match /trades/{tradeId} {
      allow read, write: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
