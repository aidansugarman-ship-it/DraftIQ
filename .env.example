# ─────────────────────────────────────────────────────────────────────────────
# DraftIQ Environment Variables
# Copy this file to .env and fill in real values. NEVER commit .env to git.
# All EXPO_PUBLIC_ vars are bundled into the client — keep them non-secret.
# ─────────────────────────────────────────────────────────────────────────────

# Firebase — Client SDK (safe to expose, scoped by Security Rules)
EXPO_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
EXPO_PUBLIC_FIREBASE_APP_ID=your_app_id

# RevenueCat — Public SDK keys (safe to expose)
EXPO_PUBLIC_REVENUECAT_API_KEY_IOS=appl_xxxxxxxxxxxxxxxxxxxxxxxx
EXPO_PUBLIC_REVENUECAT_API_KEY_ANDROID=goog_xxxxxxxxxxxxxxxxxxxxxxxx

# Google Sign-In Web Client ID (safe to expose)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your_web_client_id.apps.googleusercontent.com

# The Odds API (safe to expose — free tier key)
EXPO_PUBLIC_ODDS_API_KEY=your_odds_api_key

# ─────────────────────────────────────────────────────────────────────────────
# Firebase Cloud Functions secrets — set via Firebase CLI, NEVER in client code
# firebase functions:secrets:set ANTHROPIC_API_KEY
# firebase functions:secrets:set GEMINI_API_KEY
# firebase functions:secrets:set YOUTUBE_API_KEY
# ─────────────────────────────────────────────────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...   ← server-side only, set via CLI
# GEMINI_API_KEY=AIza...          ← server-side only, set via CLI
# YOUTUBE_API_KEY=AIza...         ← server-side only, set via CLI (reserved for future use)
